<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Theme.MusicHub — DayNight base.
      Day   (MODE_NIGHT_NO)  = Gold Rush: values/colors.xml light scheme.
      Night (MODE_NIGHT_YES) = Aurora:    values-night/colors.xml dark scheme.
    -->
    <style name="Theme.MusicHub" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_deeper</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold_primary</item>
        <item name="colorSecondaryVariant">@color/gold_dark</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:textColorPrimary">#1A0030</item>
        <item name="android:textColorSecondary">#4A4A6A</item>
        <item name="android:textColorHint">#9090B0</item>
        <item name="textColorMuted">#9090B0</item>
        <item name="textColorSectionTitle">#1A0030</item>
        <item name="inputBgColor">@color/search_bar_bg</item>
        <item name="inputStrokeColor">@color/search_bar_stroke</item>
        <item name="android:fontFamily">@font/font_space_grotesk</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <!-- Light status bar for Gold Rush (day); night override in values-night/themes.xml -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <!-- Gold Rush accent fills (day mode) -->
        <item name="chipActiveFill">#336B21A8</item>
        <item name="chipActiveStroke">#666B21A8</item>
        <item name="accentCardFill">#1A6B21A8</item>
        <item name="accentCardStroke">#336B21A8</item>
        <item name="waveformBarColor">#886B21A8</item>
        <item name="nowPlayingCardBg">#336B21A8</item>
    </style>

    <!--
      Theme.MusicHub.Midnight — standalone neon-blue dark theme.
      Applied via activity.setTheme() when theme_name = "midnight".
      Uses NoActionBar (not DayNight) so day/night system is bypassed.
      Background: #000820  |  Accent: #4F6EF7  |  Cyan glow: #00D4FF
    -->
    <style name="Theme.MusicHub.Midnight" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Background: #000820 — deep navy, NOT Aurora's purple #07000F -->
        <item name="android:windowBackground">#000820</item>
        <item name="android:colorBackground">#000820</item>
        <item name="colorSurface">#050D2A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnBackground">#FFFFFF</item>
        <!-- Primary accent: #4F6EF7 — neon blue, NOT Aurora's #7C3AED purple -->
        <item name="colorPrimary">#4F6EF7</item>
        <item name="colorPrimaryVariant">#3451D1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorAccent">#4F6EF7</item>
        <item name="colorSecondary">#00D4FF</item>
        <item name="colorSecondaryVariant">#0099BB</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorControlHighlight">#334F6EF7</item>
        <!-- Text -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#B0B8D4</item>
        <item name="android:textColorHint">#33FFFFFF</item>
        <item name="android:fontFamily">@font/font_space_grotesk</item>
        <!-- Status / nav bars -->
        <item name="android:statusBarColor">#000820</item>
        <item name="android:navigationBarColor">#000820</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <!-- Midnight adaptive text colors — must be set so @color/text_muted and @color/section_title resolve correctly -->
        <item name="textColorMuted">#7080A0</item>
        <item name="textColorSectionTitle">#4F6EF7</item>
        <!-- Midnight input backgrounds — dark navy instead of light lavender from Gold Rush -->
        <item name="inputBgColor">#0D1B3E</item>
        <item name="inputStrokeColor">#4C4F6EF7</item>
        <!-- Midnight neon-blue accent fills (all hardcoded — zero @color/ refs) -->
        <item name="chipActiveFill">#334F6EF7</item>
        <item name="chipActiveStroke">#664F6EF7</item>
        <item name="accentCardFill">#1A4F6EF7</item>
        <item name="accentCardStroke">#334F6EF7</item>
        <item name="waveformBarColor">#884F6EF7</item>
        <item name="nowPlayingCardBg">#334F6EF7</item>
    </style>

    <!-- Text styles -->
    <style name="TextStyle.Display" parent="Widget.MaterialComponents.TextView">
        <item name="android:fontFamily">@font/font_bebas</item>
        <item name="android:textColor">?android:textColorPrimary</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="TextStyle.Body" parent="Widget.MaterialComponents.TextView">
        <item name="android:fontFamily">@font/font_dm_sans</item>
        <item name="android:textColor">?android:textColorSecondary</item>
    </style>

    <style name="TextStyle.Meta" parent="Widget.MaterialComponents.TextView">
        <item name="android:fontFamily">@font/font_space_grotesk</item>
        <item name="android:textColor">?attr/textColorMuted</item>
    </style>

</resources>

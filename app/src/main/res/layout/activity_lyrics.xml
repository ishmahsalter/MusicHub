<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="0dp">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_down"
            android:padding="4dp"
            android:alpha="0.35"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LYRICS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="@font/font_bebas"
            android:letterSpacing="0.2"
            android:layout_centerInParent="true" />

        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_dots"
            android:padding="4dp"
            android:alpha="0.35"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

    <!-- Mini Player Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Mini album art -->
        <androidx.cardview.widget.CardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="7dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/purple_deeper">

            <ImageView
                android:id="@+id/iv_mini_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:padding="6dp"
                app:tint="@color/text_muted" />

        </androidx.cardview.widget.CardView>

        <!-- Track info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_lyrics_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Track Name"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="@font/font_space_grotesk"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_lyrics_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/font_dm_sans" />

        </LinearLayout>

        <!-- SYNCED badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_synced_badge"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/gold_primary"
                android:layout_marginEnd="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYNCED"
                android:textColor="@color/gold_primary"
                android:textSize="8sp"
                android:fontFamily="@font/font_space_grotesk" />

        </LinearLayout>

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/seek_progress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:progressDrawable="@drawable/bg_progress_splash"
        android:indeterminate="false"
        android:progress="0"
        android:layout_marginBottom="2dp" />

    <!-- Timestamps -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:fontFamily="@font/font_dm_sans" />

        <TextView
            android:id="@+id/tv_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:30"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:fontFamily="@font/font_dm_sans" />

    </LinearLayout>

    <!-- Lyrics ScrollView -->
    <ScrollView
        android:id="@+id/scroll_lyrics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/ll_lyrics_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp"
            android:paddingTop="8dp" />

    </ScrollView>

    <!-- Font Size + Share Lyric buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <!-- Font Size -->
        <LinearLayout
            android:id="@+id/btn_font_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_fontsize_btn"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_text_size"
                app:tint="#B3C084FC"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Size"
                android:textColor="#B3C084FC"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />

        </LinearLayout>

        <!-- Share Lyric -->
        <LinearLayout
            android:id="@+id/btn_share_lyric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_share_lyric_btn"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_share"
                app:tint="#B3D4AF37"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share Lyric"
                android:textColor="#B3D4AF37"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:background="?attr/colorSurface">

        <!-- HOME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOME"
                android:textColor="@color/text_primary"
                android:textSize="8sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- FIND -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIND"
                android:textColor="@color/text_primary"
                android:textSize="8sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- FAB -->
        <ImageView
            android:id="@+id/btn_play"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_pause"
            android:padding="11dp"
            android:background="@drawable/bg_play_btn"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- FAVS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_heart"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAVS"
                android:textColor="@color/text_primary"
                android:textSize="8sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- ME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ME"
                android:textColor="@color/text_primary"
                android:textSize="8sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="0dp">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_down"
            android:padding="4dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOW PLAYING"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/font_bebas"
            android:letterSpacing="0.2"
            android:layout_centerInParent="true" />

        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_dots"
            android:padding="4dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

    <!-- Album Art -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card">

        <ImageView
            android:id="@+id/iv_album_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_gradient_purple" />

    </androidx.cardview.widget.CardView>

    <!-- Track Info + Like -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_track_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Track Name"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.05"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_artist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist · Album · Year"
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/font_dm_sans"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/iv_like"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_heart"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Progress Bar -->
    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:progressTint="@color/purple_primary"
        android:progressBackgroundTint="#14FFFFFF"
        android:thumbTint="@color/gold_primary"
        android:minHeight="4dp"
        android:maxHeight="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#44FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/font_dm_sans" />

        <TextView
            android:id="@+id/tv_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3:20"
            android:textColor="#44FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/font_dm_sans" />

    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <!-- Shuffle -->
        <ImageView
            android:id="@+id/btn_shuffle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_shuffle"
            android:padding="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:layout_marginEnd="12dp" />

        <!-- Skip Prev -->
        <ImageView
            android:id="@+id/btn_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_prev"
            android:padding="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:layout_marginEnd="12dp" />

        <!-- Play/Pause — besar dengan glow -->
        <ImageView
            android:id="@+id/btn_play"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_pause"
            android:padding="14dp"
            android:background="@drawable/bg_play_main_btn"
            android:layout_marginEnd="12dp" />

        <!-- Skip Next -->
        <ImageView
            android:id="@+id/btn_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:padding="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:layout_marginEnd="12dp" />

        <!-- Repeat -->
        <ImageView
            android:id="@+id/btn_repeat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_repeat"
            android:padding="8dp"
            android:background="@drawable/bg_ctrl_btn" />

    </LinearLayout>

    <!-- Action Row: Lyrics, Playlist, Album, Artist, Share -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <!-- Lyrics -->
        <LinearLayout
            android:id="@+id/btn_lyrics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="4dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_microphone"
                android:tint="@color/purple_glow" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lyrics"
                android:textColor="@color/purple_glow"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />
        </LinearLayout>

        <!-- Playlist -->
        <LinearLayout
            android:id="@+id/btn_add_playlist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="4dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_playlist_add"
                android:tint="@color/gold_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlist"
                android:textColor="@color/gold_primary"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />
        </LinearLayout>

        <!-- Album -->
        <LinearLayout
            android:id="@+id/btn_album"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="4dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_vinyl"
                android:tint="@color/purple_glow" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Album"
                android:textColor="@color/purple_glow"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />
        </LinearLayout>

        <!-- Artist -->
        <LinearLayout
            android:id="@+id/btn_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="4dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_user_circle"
                android:tint="@color/purple_glow" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="@color/purple_glow"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />
        </LinearLayout>

        <!-- Share -->
        <LinearLayout
            android:id="@+id/btn_share"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="4dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_share"
                android:tint="#66FFFFFF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Home -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="2dp"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOME"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Find -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="2dp"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIND"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- FAB -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_pause"
            android:padding="12dp"
            android:background="@drawable/bg_play_btn"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Favs -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="2dp"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_heart" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAVS"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Me -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:gap="2dp"
            android:alpha="0.3">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ME"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.1" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
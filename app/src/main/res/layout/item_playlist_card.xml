<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <!-- Square cover with rounded corners -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        app:layout_constraintDimensionRatio="H,1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

    </androidx.cardview.widget.CardView>

    <!-- Playlist name -->
    <TextView
        android:id="@+id/tv_playlist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Playlist"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:fontFamily="@font/font_space_grotesk"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingTop="8dp"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        app:layout_constraintTop_toBottomOf="@id/cv_cover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Track count -->
    <TextView
        android:id="@+id/tv_track_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="0 tracks"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="@font/font_dm_sans"
        android:paddingTop="2dp"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_playlist_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

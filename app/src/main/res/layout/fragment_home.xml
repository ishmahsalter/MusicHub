<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo + Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_musichub_logo"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MUSICHUB"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.2" />

        </LinearLayout>

        <!-- Greeting -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOOD EVENING"
            android:textColor="#66FFFFFF"
            android:textSize="10sp"
            android:fontFamily="@font/font_dm_sans"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR SOUND AWAITS"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="@font/font_bebas"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#15A855F7"
            app:cardCornerRadius="11dp"
            app:cardElevation="0dp"
            app:strokeColor="#33A855F7"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    android:tint="#99C084FC"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_search_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Search tracks, artists, albums..."
                    android:textColor="#44FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/font_dm_sans" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Genre Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:id="@+id/ll_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_trending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ Trending"
                    android:textColor="#E9D5FF"
                    android:textSize="11sp"
                    android:fontFamily="@font/font_space_grotesk"
                    android:background="@drawable/bg_chip_active"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_pop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pop"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/font_space_grotesk"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_hiphop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hip-Hop"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/font_space_grotesk"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_rnb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R&amp;B"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/font_space_grotesk"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_rock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rock"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/font_space_grotesk"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- NOW PLAYING section title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="◈ NOW PLAYING"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="queue →"
                android:textColor="#33FFFFFF"
                android:textSize="11sp"
                android:fontFamily="@font/font_dm_sans" />

        </LinearLayout>

        <!-- NOW PLAYING Card glassmorphism -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#33A855F7"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#47A855F7"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- Track row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Album art mini -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="9dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#6D28D9">

                        <ImageView
                            android:id="@+id/iv_np_art"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_music_note"
                            android:scaleType="centerCrop"
                            android:padding="8dp"
                            android:tint="#66FFFFFF" />

                    </androidx.cardview.widget.CardView>

                    <!-- Track info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_np_track"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Not Playing"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="@font/font_space_grotesk"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tv_np_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tap a track to play"
                            android:textColor="#66FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/font_dm_sans"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                    <!-- HOT Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOT"
                        android:textColor="@color/gold_primary"
                        android:textSize="9sp"
                        android:fontFamily="@font/font_space_grotesk"
                        android:background="@drawable/bg_hot_badge"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                </LinearLayout>

                <!-- Waveform -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="3dp">

                    <View android:layout_width="2dp" android:layout_height="8dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="14dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="17dp" android:background="#AAD4AF37" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="9dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="12dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="16dp" android:background="#AAD4AF37" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="6dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="11dp" android:background="#88A855F7" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="15dp" android:background="#AAD4AF37" android:layout_marginEnd="2dp"/>
                    <View android:layout_width="2dp" android:layout_height="8dp" android:background="#88A855F7"/>

                </LinearLayout>

                <!-- Controls mini -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_np_prev"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_skip_prev"
                        android:padding="4dp"
                        android:tint="#66FFFFFF"
                        android:layout_marginEnd="12dp" />

                    <ImageView
                        android:id="@+id/btn_np_play"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_pause"
                        android:padding="8dp"
                        android:background="@drawable/bg_play_main_btn"
                        android:layout_marginEnd="12dp" />

                    <ImageView
                        android:id="@+id/btn_np_next"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_skip_next"
                        android:padding="4dp"
                        android:tint="#66FFFFFF"
                        android:layout_marginEnd="12dp" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_repeat"
                        android:padding="4dp"
                        android:tint="#66FFFFFF" />

                </LinearLayout>

                <!-- Progress bar mini -->
                <ProgressBar
                    android:id="@+id/pb_np"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:progressDrawable="@drawable/bg_progress_splash"
                    android:indeterminate="false"
                    android:progress="60"
                    android:layout_marginBottom="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1:52"
                        android:textColor="#33FFFFFF"
                        android:textSize="9sp"
                        android:fontFamily="@font/font_dm_sans" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3:20"
                        android:textColor="#33FFFFFF"
                        android:textSize="9sp"
                        android:fontFamily="@font/font_dm_sans" />
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- No Network -->
        <LinearLayout
            android:id="@+id/ll_no_network"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No internet connection"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:fontFamily="@font/font_dm_sans"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                android:textColor="@color/white"
                android:backgroundTint="@color/purple_dark" />

        </LinearLayout>

        <!-- TRENDING section title -->
        <TextView
            android:id="@+id/tv_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRENDING"
            android:textColor="@color/gold_primary"
            android:textSize="11sp"
            android:fontFamily="@font/font_bebas"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <!-- Trending RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_trending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
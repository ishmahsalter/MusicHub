<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="match_parent"
    android:layout_marginEnd="10dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/accentCardStroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Album art -->
        <ImageView
            android:id="@+id/iv_chart_art"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="?attr/colorSurface" />

        <!-- Rank -->
        <TextView
            android:id="@+id/tv_chart_rank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#1"
            android:textColor="@color/gold_primary"
            android:textSize="11sp"
            android:fontFamily="@font/font_bebas"
            android:letterSpacing="0.1"
            android:layout_marginTop="8dp" />

        <!-- Track name -->
        <TextView
            android:id="@+id/tv_chart_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Name"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="@font/font_space_grotesk"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Artist name -->
        <TextView
            android:id="@+id/tv_chart_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:fontFamily="@font/font_dm_sans"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Play count -->
        <TextView
            android:id="@+id/tv_chart_plays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 plays"
            android:textColor="#88D4AF37"
            android:textSize="9sp"
            android:fontFamily="@font/font_dm_sans"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>

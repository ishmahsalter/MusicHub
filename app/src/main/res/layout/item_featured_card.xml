<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_featured_card"
    android:padding="14dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp">

    <!-- Badge -->
    <TextView
        android:id="@+id/tv_card_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔥 TOP TRACK"
        android:textColor="@color/gold_primary"
        android:textSize="9sp"
        android:fontFamily="@font/font_bebas"
        android:letterSpacing="0.2"
        android:background="@drawable/bg_hot_badge"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="10dp" />

    <!-- Content row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Art -->
        <ImageView
            android:id="@+id/iv_card_art"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="12dp"
            android:background="@color/purple_deeper"
            android:scaleType="centerCrop" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Track Name"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/font_bebas"
                android:letterSpacing="0.05"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:fontFamily="@font/font_dm_sans"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_card_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="42.3M streams"
                android:textColor="@color/gold_primary"
                android:textSize="10sp"
                android:fontFamily="@font/font_space_grotesk"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Play button -->
        <ImageView
            android:id="@+id/btn_card_play"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:padding="9dp"
            android:background="@drawable/bg_play_main_btn" />

    </LinearLayout>

</LinearLayout>